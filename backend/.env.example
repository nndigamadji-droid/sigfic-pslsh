NODE_ENV=production
PORT=3000

# Generer une valeur forte:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=remplacer_par_un_secret_de_96_caracteres_hexadecimaux
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# URL publique du frontend Netlify, par exemple:
# https://sigfic-pslsh.netlify.app
FRONTEND_URL=https://votre-site.netlify.app

# Local par defaut: SQLite dans database/schema/pslsh.db.
# Production Render: DATABASE_URL est injecte automatiquement par render.yaml.
DATABASE_URL=
DATABASE_SSL=false
DATABASE_STORAGE_PATH=../../database/schema/pslsh.db

# Stockage local en developpement. En production institutionnelle, prevoir
# un stockage persistant sauvegarde pour les pieces jointes.
UPLOAD_PATH=../../storage/uploads
