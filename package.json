{
  "name": "sigfic-pslsh",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "lint": "eslint . && stylelint \"frontend/**/*.{css,html}\"",
    "lint:fix": "eslint . --fix && stylelint \"frontend/**/*.{css,html}\" --fix",
    "format": "prettier --write \"**/*.{js,json,css,md,html}\"",
    "test": "cd backend && npm test",
    "prepare": "husky"
  },
  "devDependencies": {
    "eslint": "^9.15.0",
    "globals": "^15.12.0",
    "stylelint": "^16.10.0",
    "stylelint-config-standard": "^36.0.1",
    "prettier": "^3.3.3",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10"
  },
  "lint-staged": {
    "*.js": "eslint --fix --max-warnings=0",
    "*.{css,html}": "stylelint --fix",
    "*.{json,md}": "prettier --write"
  }
}
